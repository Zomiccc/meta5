# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fxons_db

# Backend
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://localhost:3000

# Cloudflare R2 (KYC image storage)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=fxons-kyc

# Google Gemini 1.5 Flash (free tier: 15 req/min, 1500/day)
# Get your free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Twelve Data (real-time price feed)
TWELVE_DATA_API_KEY=your-twelve-data-api-key

# OANDA REST API (real trading — no MT5 server needed)
# Sign up at https://www.oanda.com → get API key from account settings
# Environment: 'practice' (demo with virtual money) or 'trade' (real money)
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=001-001-12345-001
OANDA_ENVIRONMENT=practice

# NOWPayments
NOWPAYMENTS_API_KEY=your-nowpayments-key
NOWPAYMENTS_WEBHOOK_SECRET=your-webhook-secret

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@fxons.com

# TRON / USDT-TRC20 Hot Wallet (deposits + withdrawals)
# This is the broker's wallet that receives deposits and sends withdrawals.
# TRON_HOT_WALLET_PRIVATE_KEY = the private key of the wallet (KEEP SECRET)
# TRON_HOT_WALLET_ADDRESS = the TRON address (auto-derived if private key set)
TRON_HOT_WALLET_PRIVATE_KEY=your-tron-private-key
TRON_HOT_WALLET_ADDRESS=your-tron-wallet-address
TRON_FULL_HOST=https://api.trongrid.io
TRONGRID_API_KEY=your-trongrid-api-key

# Deposit Wallet Addresses (legacy fallback for BTC/non-USDT)
DEPOSIT_USDT_ADDRESS=your-usdt-trc20-wallet-address
DEPOSIT_BTC_ADDRESS=your-btc-wallet-address
