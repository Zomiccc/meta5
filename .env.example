# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fxons_db

# Backend
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this
FRONTEND_URL=http://localhost:3000

# Cloudflare R2 (KYC image storage)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=fxons-kyc

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# Twelve Data (real-time price feed)
TWELVE_DATA_API_KEY=your-twelve-data-api-key

# OANDA REST API (real trading — no MT5 server needed)
# Sign up at https://www.oanda.com → get API key from account settings
# Environment: 'practice' (demo with virtual money) or 'trade' (real money)
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=001-001-12345-001
OANDA_ENVIRONMENT=practice

# NOWPayments
NOWPAYMENTS_API_KEY=your-nowpayments-key
NOWPAYMENTS_WEBHOOK_SECRET=your-webhook-secret

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@fxons.com

# Deposit Wallet Addresses (broker's receiving addresses)
# These are the addresses users send crypto to for deposits
DEPOSIT_USDT_ADDRESS=your-usdt-trc20-wallet-address
DEPOSIT_BTC_ADDRESS=your-btc-wallet-address
